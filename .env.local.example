# ─── Resend (email) ────────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address for confirmation emails.
# Must be a verified domain in Resend. Until domain is verified, leave unset
# to fall back to onboarding@resend.dev (Resend's free sandbox sender).
# TODO: Set to waitlist@petbindr.com once petbindr.com is verified in Resend.
RESEND_FROM_EMAIL=waitlist@petbindr.com

# ─── Firebase Admin SDK ────────────────────────────────────────────────────────
# Firebase project ID (same project as the iOS app)
FIREBASE_PROJECT_ID=petbindr-2d4bd

# Service account credentials as a base64-encoded JSON string.
# To encode: base64 -i serviceAccount.json | tr -d '\n'
# Or paste the raw JSON string directly — both formats are supported.
#
# How to create a service account:
#   1. Firebase Console → Project Settings → Service Accounts
#   2. Click "Generate new private key"
#   3. Download the JSON file
#   4. Encode it: base64 -i serviceAccount.json | tr -d '\n'
#   5. Paste the output here
FIREBASE_SERVICE_ACCOUNT_JSON=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwicHJvamVjdF9pZCI6InBldGJpbmRyLTJkNGJkIi4uLn0=
